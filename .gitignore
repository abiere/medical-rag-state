# Books — large binary files, not tracked in git
books/
*.pdf
*.epub

# Videos — large binary files, not tracked in git
videos/
*.mp4
*.mov
*.mkv
*.m4v

# Generated audit reports
data/book_quality/

# Environment / secrets
.env
.env.*
*.env

# Data directories — ignore large/generated content, track metadata files
data/extracted_images/
data/ollama/
data/qdrant/
data/processing_logs/
data/transcripts/*.json
data/transcripts/*.txt

# Backup files — large binaries and daily JSON copies, not tracked in git
backups/qdrant/
backups/metadata/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# OS / editor
.DS_Store
*.swp
*.swo
.idea/
.vscode/
